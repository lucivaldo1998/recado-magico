    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "helmet": "^8.0.0",
    "mercadopago": "^2.0.15",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
